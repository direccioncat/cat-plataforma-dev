# Variables de entorno - cat-api
# Copiar este archivo como .env y completar los valores

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cat_plataforma
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# JWT
JWT_SECRET=cambiar_por_una_clave_larga_y_segura_en_produccion
JWT_EXPIRES_IN=8h

# CORS - URL del frontend
FRONTEND_URL=http://localhost:5173

# Archivos subidos
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Google Maps
GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps_aqui
